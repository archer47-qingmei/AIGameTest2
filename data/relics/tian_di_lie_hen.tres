[gd_resource type="Resource" script_class="RelicData" format=3]

[ext_resource type="Script" path="res://RelicData.gd" id="1_RelicData"]

[resource]
script = ExtResource("1_RelicData")
display_name = "天地裂痕碎片"
description = "每场战斗真气上限 +1\n\n一粒极小的碎片。它自己也不知道自己原来是哪里的一部分——只知道落下来的时候，穿过了一段很长的黑暗。它记得那个黑暗的长度。你握着它的时候，真气回路里多了一小段不属于你的脉。"
trigger = 0
effect_type = 6
value = 1
price = 150
