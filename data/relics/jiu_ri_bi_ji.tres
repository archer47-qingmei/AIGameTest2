script = ExtResource("1_RD")
display_name = "旧日笔迹"
description = "一本薄册。前几页全是基础错误——一个人从零开始自学五行功法的笔记。后几页另起一种笔迹，把前面每一行错的都改过来了。两种笔迹不是同一个人。改错的那个人没有名字。\n\n牌组上限 +2"
