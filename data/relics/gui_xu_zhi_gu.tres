script = ExtResource("1_RD")
display_name = "归墟指骨"
description = "每场战斗，你的第一张招式牌伤害 +3\n\n一小截骨头。不是人的。它死了很久，但灵力还在骨头里走。像是在跑——已经不知道目的地了，但还在跑。"
