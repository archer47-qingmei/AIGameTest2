[resource]
script = ExtResource("1_RelicData")
display_name = "碎镜片"
description = "整局首次致命伤害改为 HP 降为 1（触发后碎裂）\n\n一片极薄的晶体，从湖面浮上来的。上面映的不是你的脸——是你上一次死在什么地方的姿势。你每次看，那个姿势都离你远了一点点。"
trigger = 0
effect_type = 16
value = 0
price = 100
