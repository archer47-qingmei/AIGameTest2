[resource]
script = ExtResource("1_RelicData")
display_name = "朔之回音"
description = "HP 低于 30% 时，每回合开始额外抽 1 张牌\n\n一粒暗淡的法器。里面封着三次极短的闪烁。不是道法，不是文字，就是亮。它不亮的时候是空的。亮的时候——恰好在你最暗的时候。"
trigger = 1
effect_type = 14
value = 1
price = 150
