script = ExtResource("1_RD")
display_name = "灵根残枝"
description = "你所有功法牌的真气消耗 -1（最低 1）\n\n一截枯了的灵脉。已经死了。但你摸它的时候，内部的灵气经络还在走——一圈一圈。像死掉的树还在打年轮。"
