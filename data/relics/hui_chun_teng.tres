script = ExtResource("1_RelicData")
display_name = "回春藤"
description = "HP 首次降到 50% 以下时，自动回复 30% 最大 HP。\n\n一截枯藤，有人在上面刻了一个「活」字。刻完就枯了。但捏着它的时候，掌心会微微发热。"
