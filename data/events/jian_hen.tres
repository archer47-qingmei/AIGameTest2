[resource]
script = ExtResource("1_ED")
display_name = "剑痕"
mood = "神秘"
flavor_text = "山壁上有一道很新的剑痕——是今天劈的。这不是你留下的。你拔剑对着那道痕比了一下：角度不同，力道也不一样。不是你。是一个和你用不同握法的人。剑痕旁边有一小块烤焦的红薯皮。红薯皮还是热的。"
choices = [SubResource("c1"), SubResource("c2")]
appear_condition = 0
appear_condition_value = 0
character_requirement = "sword"
