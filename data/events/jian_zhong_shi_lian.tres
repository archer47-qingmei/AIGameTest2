[resource]
script = ExtResource("1_ED")
display_name = "剑冢试炼"
mood = "神秘"
flavor_text = "满地断剑，插在土里。中间一把浮在空中。旁边站着一个残影——不是人，是上一任主人留下的最后一道剑式。他走的时候没有收式。"
choices = [SubResource("c1"), SubResource("c2"), SubResource("c3")]
