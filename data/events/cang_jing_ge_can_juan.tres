cost_gold = 0

[resource]
script = ExtResource("1_ED")
display_name = "藏经阁残卷"
mood = "安静"
flavor_text = "废弃的藏经阁。书还在——大部分是空的。不是纸被撕了，是字从纸上走掉了。角落有一册残卷，上面的字在微弱地跳动。像脉搏。"
choices = [SubResource("c1"), SubResource("c2"), SubResource("c3")]
