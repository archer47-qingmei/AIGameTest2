cost_gold = 0

[sub_resource type="Resource" id="c3"]
script = ExtResource("2_ECD")
button_text = "不散"
result_text = "你看着他。走的时候有一阵风——他身上草叶动了。"
effects = [SubResource("e5")]
cost_gold = 0

[resource]
script = ExtResource("1_ED")
display_name = "散功重修"
mood = "感动"
flavor_text = "山道上有一个人，盘坐着。衣服风化了一半，头发里长出草叶。他在散功。自愿的。手边有一行字：「散了的功不会回来。但忘了改的毛病会。散之前想清楚。」"
choices = [SubResource("c1"), SubResource("c2"), SubResource("c3")]
appear_condition = 2
appear_condition_value = 15
character_requirement = ""
