cost_gold = 0

[sub_resource type="Resource" id="c2"]
script = ExtResource("2_ECD")
button_text = "退回雾中"
result_text = "退了一步。雾合上。集市没了。灵石少了一半。不记得什么时候给的。"
effects = [SubResource("e4")]
cost_gold = 0

[sub_resource type="Resource" id="c3"]
script = ExtResource("2_ECD")
button_text = "强行冲破"
result_text = "提起真气，强行穿过。出来了——身上全是雾刮出来的血口子。"
effects = [SubResource("e5")]
cost_gold = 0

[resource]
script = ExtResource("1_ED")
