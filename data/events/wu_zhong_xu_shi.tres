[sub_resource type="Resource" id="c1"]
script = ExtResource("2_ECD")
button_text = "进入交易"
result_text = "你拿了一件灵器，一本功法。摊主收了你的帐——不是灵石。你走出雾的时候手心多了一道裂缝。不疼。就是裂着。"
