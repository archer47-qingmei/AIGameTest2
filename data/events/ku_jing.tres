[resource]
script = ExtResource("1_ED")
display_name = "枯井"
mood = "惊悚"
flavor_text = "路边一口井。井沿上长满青苔——没有人用过很久了。但井里是亮的。有光。那光不是水反射的，是井底自己发的。你往下看的时候，那光闪了一下。像是看到了你。"
