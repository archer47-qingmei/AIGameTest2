[gd_resource type="Resource" script_class="EnemyData" load_steps=5 format=3]

[ext_resource type="Script" path="res://EnemyData.gd" id="1_EnemyData"]
[ext_resource type="Script" path="res://EnemyActionData.gd" id="2_EnemyActionData"]

[sub_resource type="Resource" id="Action_block"]
script = ExtResource("2_EnemyActionData")
type = "block"
value = 12
display_label = "铁幕"
description = "铜皮外翻，形成一层新膜。获得 12 格挡。"

[sub_resource type="Resource" id="Action_attack"]
script = ExtResource("2_EnemyActionData")
type = "attack"
value = 10
display_label = "铁拳"
description = "沉重的铜臂砸下。造成 10 点伤害。"

[resource]
script = ExtResource("1_EnemyData")
display_name = "铜甲尸"
hp = 66
actions = Array[ExtResource("2_EnemyActionData")]([SubResource("Action_block"), SubResource("Action_attack")])
