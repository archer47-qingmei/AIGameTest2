[sub_resource type="Resource" id="Action_multi"]
script = ExtResource("2_EnemyActionData")
type = "multi_attack"
value = 5
count = 2
weight = 30
display_label = "连斩"
description = "剑式未收，反手再来。连续攻击两次，各造成 5 点伤害。"

[sub_resource type="Resource" id="Action_charge"]
script = ExtResource("2_EnemyActionData")
type = "charge"
weight = 10
display_label = "蓄力"
description = "悬停在空中——剑气越来越亮。下回合攻击伤害翻倍（约 16 点）。"

[resource]
script = ExtResource("1_EnemyData")
display_name = "剑气残影"
hp = 46
random_actions = true
actions = Array[ExtResource("2_EnemyActionData")]([SubResource("Action_atk9"), SubResource("Action_multi"), SubResource("Action_charge")])
