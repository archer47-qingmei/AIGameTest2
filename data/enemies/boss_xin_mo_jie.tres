[gd_resource type="Resource" script_class="EnemyData" load_steps=5 format=3]

[ext_resource type="Script" path="res://EnemyData.gd" id="1_EnemyData"]
[ext_resource type="Script" path="res://EnemyActionData.gd" id="2_EnemyActionData"]

[sub_resource type="Resource" id="Action_mirror"]
script = ExtResource("2_EnemyActionData")
type = "mirror_attack"
value = 8
display_label = "心像"
description = "使用从你牌组中复制的招式发动攻击——是你自己的影子在打你。"

[sub_resource type="Resource" id="Action_periodic"]
script = ExtResource("2_EnemyActionData")
type = "xin_mo_fanshi"
display_label = "心魔反噬"
description = "将你手中随机 1 张牌变为心魔。"

[sub_resource type="Resource" id="Action_p3"]
script = ExtResource("2_EnemyActionData")
type = "attack_zahuorumuo"
value = 12
count = 1
display_label = "走火"
description = "HP 低于 30% 后进入走火状态。造成 12 点伤害，往弃牌堆塞 1 张走火入魔。"

[resource]
script = ExtResource("1_EnemyData")
display_name = "心魔劫"
hp = 270
copies_player_cards = true
periodic_interval = 3
periodic_action = SubResource("Action_periodic")
actions = Array[ExtResource("2_EnemyActionData")]([SubResource("Action_mirror")])
phase2_threshold = 0.3
phase2_passive_threshold = 0.5
phase2_actions = Array[ExtResource("2_EnemyActionData")]([SubResource("Action_p3")])
