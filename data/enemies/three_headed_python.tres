[gd_resource type="Resource" script_class="EnemyData" load_steps=9 format=3]

[ext_resource type="Script" path="res://EnemyData.gd" id="1_EnemyData"]
[ext_resource type="Script" path="res://EnemyActionData.gd" id="2_EnemyActionData"]

[sub_resource type="Resource" id="Action_attack"]
script = ExtResource("2_EnemyActionData")
type = "attack"
value = 15
display_label = "攻首"
description = "攻首（红眼）张嘴咬来，黏液滴落。造成 15 点伤害。"

[sub_resource type="Resource" id="Action_block"]
script = ExtResource("2_EnemyActionData")
type = "block"
value = 15
display_label = "防首"
description = "防首（青鳞）闭眼静听，鳞片外翻。获得 15 格挡。"

[sub_resource type="Resource" id="Action_curse_p1"]
script = ExtResource("2_EnemyActionData")
type = "discard_curse"
value = 2
display_label = "毒首"
description = "毒首（紫舌）吐出紫雾。往弃牌堆塞 2 张心魔。"

[sub_resource type="Resource" id="Action_attack_curse"]
script = ExtResource("2_EnemyActionData")
type = "attack_curse"
value = 15
count = 1
display_label = "攻首"
description = "攻首张嘴咬来，心魔随之蔓延。造成 15 点伤害，往弃牌堆塞 1 张心魔。"

[sub_resource type="Resource" id="Action_block_curse"]
script = ExtResource("2_EnemyActionData")
type = "block_curse"
value = 15
count = 1
display_label = "防首"
description = "防首格挡，毒首趁机偷袭。获得 15 格挡，往弃牌堆塞 1 张心魔。"

[sub_resource type="Resource" id="Action_curse_p2"]
script = ExtResource("2_EnemyActionData")
type = "discard_curse"
value = 3
display_label = "毒首"
description = "毒首在血量低时失控——浓紫色雾气大量涌出。往弃牌堆塞 3 张心魔。"

[resource]
script = ExtResource("1_EnemyData")
display_name = "三首妖蟒"
hp = 147
actions = Array[ExtResource("2_EnemyActionData")]([SubResource("Action_attack"), SubResource("Action_block"), SubResource("Action_curse_p1")])
phase2_threshold = 0.5
phase2_actions = Array[ExtResource("2_EnemyActionData")]([SubResource("Action_attack_curse"), SubResource("Action_block_curse"), SubResource("Action_curse_p2")])
